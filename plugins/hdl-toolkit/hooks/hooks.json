{
  "description": "文件保护 hook：阻止修改包含 // CLAUDE-LOCKED 标记的文件",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/check_locked.py"
          }
        ]
      }
    ]
  }
}
